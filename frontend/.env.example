# ─────────────────────────────────────────────────────
#  Frontend environment variables  (.env.local)
#  Copy this file to frontend/.env.local and fill in
#  your Asgardeo values.
# ─────────────────────────────────────────────────────

# Your Asgardeo organization name (from asgardeo.io dashboard)
VITE_ASGARDEO_ORG_NAME=your-org-name

# Client ID from the SPA application you created in Asgardeo
VITE_ASGARDEO_CLIENT_ID=your-client-id-here

# URL of this app (change to Choreo URL after deployment)
VITE_APP_URL=http://localhost:5173

# URL of the Ballerina backend API
# Local: leave empty (Vite proxy handles /api → localhost:8090)
# Production: set to your Choreo service URL
VITE_API_URL=
